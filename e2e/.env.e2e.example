# Dedicated CockroachDB Cloud test database — a second database on the SAME
# cluster as dev/prod (e.g. stockPortfolioAnalysisE2E), never the real
# stockPortfolioAnalysis database. Migrated fresh via `npm run migrate` (see
# scripts/migrate-test-db.ts) before every local test run.
DATABASE_URL=

# Same dummy values the backend CI job already uses — these protect nothing
# real, so it's fine to reuse them here rather than generate new ones.
JWT_SECRET=
API_KEY_ENCRYPTION_KEY=

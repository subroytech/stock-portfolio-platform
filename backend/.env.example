PORT=4000

# CockroachDB Cloud connection string (see Architecture.md / rebuild plan)
DATABASE_URL=

FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com/stable
FMP3_BASE_URL=https://financialmodelingprep.com/v3
FMP4_BASE_URL=https://financialmodelingprep.com/v4

FINNHUB_API_KEY=
FINNHUB_BASE_URL=https://finnhub.io/api/v1

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_PER_USER=30
RATE_LIMIT_MAX_PER_IP=60

# Auth (Phase 2). Generate a real secret, e.g. `openssl rand -hex 32` — never commit a real value.
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Frontend origin, for CORS credentials on cookie-based auth (Phase 3's real value once it exists)
FRONTEND_ORIGIN=http://localhost:3000

NODE_ENV=development
